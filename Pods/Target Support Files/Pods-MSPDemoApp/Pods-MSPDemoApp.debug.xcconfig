ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EXCLUDED_ARCHS[sdk=iphonesimulator*] = i386
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/FBAudienceNetwork/Dynamic" "${PODS_ROOT}/Google-Mobile-Ads-SDK/Frameworks/GoogleMobileAdsFramework" "${PODS_ROOT}/GoogleUserMessagingPlatform/Frameworks/Release" "${PODS_ROOT}/MSPCore/Binary" "${PODS_ROOT}/MSPFacebookAdapter/Binary" "${PODS_ROOT}/MSPGoogleAdapter/Binary" "${PODS_ROOT}/MSPGoogleAdsTypes/Binary" "${PODS_ROOT}/MSPNovaAdapter/Binary" "${PODS_ROOT}/MSPPrebidAdapter/Binary" "${PODS_ROOT}/MSPSharedLibraries/Binary" "${PODS_ROOT}/MSPSharedLibraries/ThirdParty/MSPSnapKit" "${PODS_ROOT}/MSPSharedLibraries/ThirdParty/OMSDK" "${PODS_ROOT}/MSPSharedLibraries/ThirdParty/PrebidMobile" "${PODS_ROOT}/MSPiOSCore/Binary" "${PODS_XCFRAMEWORKS_BUILD_DIR}/FBAudienceNetwork" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Google-Mobile-Ads-SDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/GoogleUserMessagingPlatform" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPCore" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPFacebookAdapter" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPGoogleAdapter" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPGoogleAdsTypes" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPNovaAdapter" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPPrebidAdapter" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPSharedLibraries" "${PODS_XCFRAMEWORKS_BUILD_DIR}/MSPiOSCore"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Google-Mobile-Ads-SDK" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftProtobuf" "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Google-Mobile-Ads-SDK/Google_Mobile_Ads_SDK.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SwiftProtobuf/SwiftProtobuf.modulemap"
OTHER_LDFLAGS = $(inherited) -ObjC -l"Google-Mobile-Ads-SDK" -l"SwiftProtobuf" -l"c++" -l"sqlite3" -l"xml2" -l"z" -framework "AVFAudio" -framework "AVFoundation" -framework "AppTrackingTransparency" -framework "AudioToolbox" -framework "CFNetwork" -framework "CoreAudio" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreMedia" -framework "CoreTelephony" -framework "CoreVideo" -framework "FBAudienceNetwork" -framework "Foundation" -framework "GoogleMobileAds" -framework "JavaScriptCore" -framework "MSPCore" -framework "MSPFacebookAdapter" -framework "MSPGoogleAdapter" -framework "MSPGoogleAdsTypes" -framework "MSPNovaAdapter" -framework "MSPPrebidAdapter" -framework "MSPSharedLibraries" -framework "MSPSnapKit" -framework "MSPiOSCore" -framework "MediaPlayer" -framework "MessageUI" -framework "MobileCoreServices" -framework "Network" -framework "NovaCore" -framework "OMSDK_Newsbreak1" -framework "PrebidMobile" -framework "QuartzCore" -framework "Security" -framework "StoreKit" -framework "SystemConfiguration" -framework "UIKit" -framework "UserMessagingPlatform" -framework "WebKit" -weak_framework "AdSupport" -weak_framework "CFNetwork" -weak_framework "CoreMotion" -weak_framework "CoreTelephony" -weak_framework "JavaScriptCore" -weak_framework "LocalAuthentication" -weak_framework "SafariServices" -weak_framework "SystemConfiguration" -weak_framework "VideoToolbox" -weak_framework "WebKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/FBAudienceNetwork" "-F${PODS_CONFIGURATION_BUILD_DIR}/Google-Mobile-Ads-SDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/GoogleUserMessagingPlatform" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPCore" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPFacebookAdapter" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPGoogleAdapter" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPGoogleAdsTypes" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPNovaAdapter" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPPrebidAdapter" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPSharedLibraries" "-F${PODS_CONFIGURATION_BUILD_DIR}/MSPiOSCore" "-F${PODS_CONFIGURATION_BUILD_DIR}/SwiftProtobuf"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/Google-Mobile-Ads-SDK/Google_Mobile_Ads_SDK.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/SwiftProtobuf/SwiftProtobuf.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/..
PODS_ROOT = ${SRCROOT}/../Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/FBAudienceNetwork" "${PODS_CONFIGURATION_BUILD_DIR}/Google-Mobile-Ads-SDK" "${PODS_CONFIGURATION_BUILD_DIR}/MSPCore" "${PODS_CONFIGURATION_BUILD_DIR}/MSPFacebookAdapter" "${PODS_CONFIGURATION_BUILD_DIR}/MSPGoogleAdapter" "${PODS_CONFIGURATION_BUILD_DIR}/MSPGoogleAdsTypes" "${PODS_CONFIGURATION_BUILD_DIR}/MSPNovaAdapter" "${PODS_CONFIGURATION_BUILD_DIR}/MSPPrebidAdapter" "${PODS_CONFIGURATION_BUILD_DIR}/MSPSharedLibraries" "${PODS_CONFIGURATION_BUILD_DIR}/MSPiOSCore" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftProtobuf" $(inherited) $(PODS_CONFIGURATION_BUILD_DIR)
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
